# ============================================================
# Variables de entorno para el frontend (Vite)
# Copia este archivo como .env y completa los valores
# ============================================================

# URL de tu proyecto Supabase (ej: https://abcdefg.supabase.co)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave anon/pública de Supabase (NO la service_role_key)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...tu_anon_key

# ID del proyecto Supabase (solo el identificador, ej: abcdefg)
VITE_SUPABASE_PROJECT_ID=tu_project_id
